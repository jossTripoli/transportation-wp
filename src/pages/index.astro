---
import "../styles/global.css";
import TransportationSection from "../components/hero/high-impact/index";
import { fetchGraphQL } from "../lib/wordpress";
import { HOME_TRANSPORTATION_QUERY } from "../lib/queries";
import type { TransportationTabsData } from "../components/hero/high-impact/types";

type HomeTransportationResponse = {
  page: {
    title: string;
    homeHeroSection: TransportationTabsData;
  };
};

const data = await fetchGraphQL<HomeTransportationResponse>(
  HOME_TRANSPORTATION_QUERY
);

const transportationData = data.page.homeHeroSection;
---

<html lang="en">
  <head>
    <title>The ABC Transportation Experience</title>
    <meta
      name="description"
      content="Transportation service features including driver clearances, GPS tracking, accessible vehicles, easy booking, customer support, and safety standards."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>

  <body>
    <main>
      <TransportationSection data={transportationData} client:load />
    </main>
  </body>
</html>